# Claude MCP Environment Variables
# Copy this file to .env and fill in machine-specific values
# NEVER commit .env — it is gitignored

# Memory MCP
# Windows example: C:\Users\yourname\.claude-memory\memory.json
# Mac example:     /Users/yourname/.claude-memory/memory.json
CLAUDE_MEMORY_FILE_PATH=C:\Users\pniu\.claude-memory\memory.json

# Outlook MCP
# Path to the outlook-mcp Node.js server on this machine
# Windows example: C:/Users/yourname/.../outlook-mcp/src/index.js
# Mac example:     /Users/yourname/.../outlook-mcp/src/index.js
OUTLOOK_MCP_PATH=C:/Users/pniu/OneDrive/My Documents/Documents/Projects/outlook-mcp/src/index.js

# Azure app registration client ID (public, safe to share)
OUTLOOK_CLIENT_ID=f522b02f-d1c6-47cb-a0e6-7ae7e82b533a

# Path to the OAuth token file (machine-local, never commit)
OUTLOOK_TOKEN_FILE=C:/Users/pniu/OneDrive/My Documents/Documents/Projects/outlook-mcp/tokens.json

# GitHub MCP
# Create a Personal Access Token at https://github.com/settings/tokens
# Required scopes: repo, read:org, read:user
# Windows/Mac example: ghp_xxxxxxxxxxxxxxxxxxxx
GITHUB_TOKEN=ghp_your_token_here

# doc-mcp (local document library — vector search via ChromaDB + Ollama)
# Prerequisites on each machine:
#   1. Clone doc-mcp repo and install deps: cd doc-mcp && python -m venv .venv && .venv/Scripts/activate && pip install -r requirements.txt
#   2. Install Ollama (https://ollama.com) and pull the embedding model: ollama pull mxbai-embed-large
#   3. Let OneDrive sync chroma_db/ before starting Claude (DB is stored in doc-mcp/chroma_db/ on OneDrive)
#   4. Only run ingest.py if adding new documents — existing chroma_db syncs via OneDrive
#
# Point to the venv python (not system python) so dependencies are always found:
# Windows: C:/path/to/doc-mcp/.venv/Scripts/python.exe
# Mac:     /path/to/doc-mcp/.venv/bin/python
DOC_MCP_PYTHON=C:/Users/pniu/OneDrive/My Documents/Documents/Projects/doc-mcp/.venv/Scripts/python.exe
DOC_MCP_SERVER_PATH=C:/Users/pniu/OneDrive/My Documents/Documents/Projects/doc-mcp/server.py
